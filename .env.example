# Cloud Mail（收码）配置 —— 必填
CM_BASE_URL=https://cloudmail.example.com
CM_ADMIN_EMAIL=admin@example.com
CM_ADMIN_PASSWORD=改成你的admin密码
CM_DOMAIN=example.com

# 访问 Cloud Mail 的代理（一般直连，留空）
CM_PROXY=

# OpenAI 注册走的代理（强烈建议住宅代理；留空=直连，可能被风控）
REGISTER_PROXY=

# HTTP 接口鉴权 key：设了之后请求需带 header  X-API-Key: <key>
API_KEY=

# 收码轮询参数（可选）
# OTP_MAX_RETRIES=40
# OTP_POLL_INTERVAL_S=3.0

# sub2api 导出（可选）
# EXPORT_SUB2API=1            # 0/false 关闭导出
# PRODUCT_DIR=product_files   # sub2api 文件根目录（容器内默认 /data/product_files）
# SUB2API_BASE_URL=https://sub2api.example.com
# SUB2API_AUTHORIZATION=Bearer <admin-jwt>

# Web 控制台批量任务（可选）
# REGISTER_DB_PATH=/data/register_console.db
# BATCH_RUN_ROOT=/data/batch_runs
# BATCH_JOB_MAX_LOG_LINES=1200
# BATCH_PURGE_AFTER_UPLOAD=1    # 上传 sub2api 成功后清理 token 产物和 DB 敏感字段

# Codex SSO（可选；POST /codex/sso 也可用请求体字段覆盖）
SSO_CONNECTION_ID=conn_xxxxxxxxxxxxxxxxxxxxxxxxxx
SSO_BASE_URL=https://sso.example.com
SSO_EMAIL_DOMAIN=example.com
CODEX_SSO_JOIN_TEAM_FIRST=true

# 本地保存模式（可选）
# CODEX_SSO_DEFAULT_UPLOAD=false
# CODEX_SSO_DEFAULT_SAVE_LOCAL=true
# CODEX_SSO_SAVE_DIR=/data/saved_accounts
# CODEX_SSO_HIDE_EMAIL_IN_RESPONSE=true
